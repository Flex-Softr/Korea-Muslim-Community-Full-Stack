# Copy to `.env` and fill in values. Never commit `.env`.

NODE_ENV=development

# SQLite (default local path relative to prisma/)
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Public URL of the app (used in emails, optional if localhost)
AUTH_URL="http://localhost:3000"

# Optional: shown in emails and UI
APP_NAME="My App"

# Optional: public site URL for sitemap/robots (falls back to AUTH_URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP — required in production for real email (password reset, verification, contact)
EMAIL_FROM="noreply@example.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Inbox for contact form submissions (recommended in production). Falls back to EMAIL_FROM if unset.
CONTACT_TO_EMAIL="you@example.com"

# Optional seed user (both or neither)
SEED_USER_EMAIL=""
SEED_USER_PASSWORD=""
SEED_USER_NAME=""
SEED_USER_ROLE="ADMIN"
