generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model CommunityMember {
  id         String  @id @default(cuid()) @map("_id")
  /// Optional display / internal membership code (e.g. BA-2024-001).
  memberCode String? @unique

  name    String
  nameBn  String?
  /// Association role on the directory (President, Volunteer coordinator, …).
  title   String?
  /// Public-facing designation shown under member name.
  designation String?
  /// Short intro (e.g. one sentence for cards and profile lead).
  aboutSummary String?
  /// Longer bio / story; separate paragraphs with blank lines.
  bio     String?
  imageUrl String?

  /// Achievements & credentials (multiline text each).
  awards              String?
  publications        String?
  researchPapers      String?
  scholarshipsHonors  String?

  /// Engagement stats — set when community feed / events are integrated; null = hide.
  activityPostsCount    Int?
  activityCommentsCount Int?
  activityEventsCount   Int?
  /// Free-form highlights (roles, committees) until automated stats exist.
  activityNotes         String?

  /// MALE | FEMALE | OTHER | PREFER_NOT_TO_SAY
  gender               String?
  dateOfBirth          DateTime?
  /// When true, only the birth year is shown to viewers allowed to see DOB.
  dateOfBirthYearOnly  Boolean @default(false)

  universityKr   String?
  degree         String?
  major          String?
  /// CURRENT_STUDENT | GRADUATED
  studyStatus    String?
  yearAdmission  Int?
  graduationYear Int?

  locationCity     String?
  /// Bangladesh division of origin (home), for directory filters — matches `BD_DIVISIONS` labels.
  homeDivisionBd String?
  /// Bangladesh district of origin under `homeDivisionBd` — matches district lists per division.
  homeDistrictBd String?
  /// STUDENT | JOB_HOLDER | BUSINESS_OWNER | OTHER
  occupationType   String?
  companyName      String?
  jobTitle         String?

  /// PUBLIC | MEMBERS_ONLY — contact, journey & DOB follow this rule.
  profileVisibility String @default("PUBLIC")
  contactEmail      String?
  phone             String?
  whatsApp          String?
  kakaoId           String?
  linkedInUrl       String?
  facebookUrl       String?

  yearArrivalKorea    Int?
  visaType            String?
  scholarshipInfo     String?
  educationBangladesh String?

  skillsTechnical   String?
  koreanLevelTopik  String?
  certifications    String?

  sortOrder Int @default(0)
  /// EXECUTIVE | ADVISOR_BODY
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([contactEmail])
}

model User {
  id                        String                    @id @default(cuid()) @map("_id")
  email                     String                    @unique
  password                  String
  name                      String?
  role                      String                    @default("USER")
  emailVerified             DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  passwordResetTokens       PasswordResetToken[]
  emailVerificationTokens   EmailVerificationToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid()) @map("_id")
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid()) @map("_id")
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// CMS blog posts (was `type: "blog"` on legacy `DashboardContent`).
model DashboardBlog {
  id          String   @id @default(cuid()) @map("_id")
  title       String
  category    String
  description String?
  coverImage  String?
  videoUrl    String?
  slug        String?
  localeContent Json?
  createdById String?
  status      String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([createdById])
  @@index([status])
  @@index([slug])
  @@index([status, createdAt])
  @@index([createdById, createdAt])
  @@index([status, category, createdAt])
}

