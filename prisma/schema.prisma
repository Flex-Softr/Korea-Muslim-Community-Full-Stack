model DashboardCategory {
  id        String   @id @default(cuid()) @map("_id")
  type      String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, slug])
  @@index([type, name])
}

model DashboardCarousel {
  id        String   @id @default(cuid()) @map("_id")
  title     String
  subtitle  String
  imageUrl  String
  ctaLabel  String?
  ctaHref   String?
  /// `{ "en": { title, subtitle, ctaLabel }, ... }`
  localeContent Json?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model AppSetting {
  id        String   @id @default(cuid()) @map("_id")
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Public contact / quick-contact form (stored when email sending is disabled).
model ContactFormSubmission {
  id           String   @id @default(cuid()) @map("_id")
  name         String
  mobileNumber String
  /// student | job_holder | eps
  occupation String
  address    String
  visaType   String
  message    String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
